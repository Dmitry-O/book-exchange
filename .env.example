# Local development values used by run-local.ps1 and docker-compose.local.yml.

BACKEND_PORT=8080
BACKEND_MANAGEMENT_PORT=8081
FRONTEND_PORT=5173
FRONTEND_CONTEXT=../book-exchange-frontend
VITE_API_BASE_URL=http://localhost:8080/api/v1

DB_NAME=book_exchange_db
DB_USERNAME=book_exchange_user
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root
DB_PORT=3307
DB_URL=jdbc:mysql://localhost:3307/book_exchange_db?useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
DB_POOL_MAX_SIZE=5
DB_MAX_LIFETIME=600000
DB_KEEPALIVE_TIME=300000
DB_VALIDATION_TIMEOUT=5000
DB_CONNECTION_TIMEOUT=30000

MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
MAILPIT_MAX_MESSAGES=500
APP_DEMO_EMAIL_SANDBOX_ENABLED=true
APP_DEMO_EMAIL_SANDBOX_MAILPIT_API_BASE_URL=http://localhost:8025
APP_DEMO_EMAIL_SANDBOX_MAILPIT_USERNAME=
APP_DEMO_EMAIL_SANDBOX_MAILPIT_PASSWORD=
APP_DEMO_EMAIL_SANDBOX_SESSION_TTL_MINUTES=180
APP_DEMO_EMAIL_SANDBOX_MAX_MESSAGES=500
APP_DEMO_EMAIL_SANDBOX_DELETE_EXPIRED_MESSAGES=true
APP_DEMO_EMAIL_SANDBOX_CLEANUP_INTERVAL_MILLIS=300000

APP_BASE_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_JWT_SECRET_KEY=replace-with-at-least-64-random-characters
APP_EMAIL_SENT_FROM=noreply@bookexchange.local
APP_ACCESS_TOKEN_TTL=54000
APP_BOOK_SEARCH_ENABLED=true
APP_BOOK_SEARCH_REINDEX_ON_STARTUP=false
APP_BOOK_SEARCH_MIN_SEARCH_LENGTH=3
APP_NOTIFICATION_EMAIL_BATCH_DELAY_MILLIS=0
APP_REPORT_SNAPSHOT_RETENTION_DAYS=180
APP_REPORT_SNAPSHOT_CLEANUP_CRON=0 45 3 * * *

APP_STORAGE_S3_REGION=eu-north-1
APP_STORAGE_S3_TEST_BUCKET=book-exchange-test
APP_STORAGE_S3_PROD_BUCKET=book-exchange-prod
APP_STORAGE_S3_USE_TEST_BUCKET=true
APP_STORAGE_IMAGE_MAX_WIDTH=1200
APP_STORAGE_IMAGE_MAX_HEIGHT=1200
APP_STORAGE_IMAGE_JPEG_QUALITY=0.82
APP_STORAGE_CLEANUP_SOFT_DELETED_BOOK_PHOTO_RETENTION_DAYS=30
APP_STORAGE_CLEANUP_SOFT_DELETED_BOOK_PHOTO_CRON=0 30 3 * * *

APP_SHOWCASE_BACKEND_GITHUB_URL=https://github.com/your-user/book-exchange
APP_SHOWCASE_FRONTEND_GITHUB_URL=https://github.com/your-user/book-exchange-frontend
APP_SHOWCASE_LINKEDIN_URL=
APP_SHOWCASE_SWAGGER_URL=http://localhost:8080/api/v1/swagger-ui/index.html

SPRING_ELASTICSEARCH_URIS=http://elasticsearch:9200
ELASTICSEARCH_PORT=9200

MANAGEMENT_PORT=8081
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health
MANAGEMENT_PROMETHEUS_ENABLED=false
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true
