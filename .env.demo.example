# Reference values for Elastic Beanstalk environment properties.
# Elastic Beanstalk generates the .env file consumed by Docker Compose.
# Store secrets in SSM Parameter Store, not in this file or deployment bundle.

DB_URL=jdbc:mysql://replace-with-rds-endpoint:3306/replace_with_demo_db?useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC&useSSL=true
DB_USERNAME=replace_with_demo_db_user
DB_PASSWORD=replace-with-ssm-or-secrets-manager-value
DB_POOL_MAX_SIZE=5
DB_MAX_LIFETIME=600000
DB_KEEPALIVE_TIME=300000
DB_VALIDATION_TIMEOUT=5000
DB_CONNECTION_TIMEOUT=30000

# CloudFront is the public entrypoint for both frontend and /api/* requests.
APP_BASE_URL=https://replace-with-cloudfront-domain.cloudfront.net
APP_FRONTEND_URL=https://replace-with-cloudfront-domain.cloudfront.net
APP_CORS_ALLOWED_ORIGINS=https://replace-with-cloudfront-domain.cloudfront.net
APP_JWT_SECRET_KEY=replace-with-ssm-or-secrets-manager-value
APP_EMAIL_SENT_FROM=noreply@example.test
APP_ACCESS_TOKEN_TTL=54000
APP_DEMO_ACCESS_TOKEN_HASH=replace-with-sha256-hash-of-demo-access-token
APP_DEMO_ACCESS_COOKIE_NAME=BE_DEMO_ACCESS
APP_DEMO_ACCESS_COOKIE_TTL_SECONDS=604800
APP_DEMO_ACCESS_SECURE_COOKIE=true
APP_DEMO_ACCOUNTS_EMAIL_PATTERN=%@example.test
APP_DEMO_ACCOUNTS_PASSWORD=replace_with_demo_account_password
APP_LOG_LEVEL=info
APP_NOTIFICATION_EMAIL_BATCH_DELAY_MILLIS=1000
APP_SCHEDULER_ZONE=Europe/Berlin

APP_BOOK_SEARCH_ENABLED=false
APP_BOOK_SEARCH_REINDEX_ON_STARTUP=false
APP_BOOK_SEARCH_MIN_SEARCH_LENGTH=3

APP_STORAGE_S3_REGION=eu-central-1
APP_STORAGE_S3_PROD_BUCKET=replace-with-demo-image-bucket
APP_STORAGE_S3_USE_TEST_BUCKET=false
APP_STORAGE_S3_KEY_PREFIX=runtime
APP_STORAGE_IMAGE_MAX_WIDTH=1200
APP_STORAGE_IMAGE_MAX_HEIGHT=1200
APP_STORAGE_IMAGE_JPEG_QUALITY=0.82
APP_STORAGE_CLEANUP_SOFT_DELETED_BOOK_PHOTO_RETENTION_DAYS=30
APP_STORAGE_CLEANUP_SOFT_DELETED_BOOK_PHOTO_CRON=0 0 0 * * *

APP_DEMO_RESET_ENABLED=true
APP_DEMO_RESET_CRON=0 0 0 * * *
APP_DEMO_RESET_ZONE=Europe/Berlin
# Upload the demo seed SQL to a private, non-public S3 prefix.
# APP_DEMO_RESET_SEED_S3_KEY points to an object inside the same bucket configured by APP_STORAGE_S3_*.
APP_DEMO_RESET_SEED_S3_KEY=private/demo-reset/replace-with-demo-seed.sql
APP_DEMO_RESET_S3_RUNTIME_PREFIX=runtime/
APP_DEMO_RESET_CLEAR_MAILPIT=true
APP_DEMO_RESET_REINDEX_SEARCH=true

# For seed data preparation only: temporarily run the backend with APP_STORAGE_S3_KEY_PREFIX=seed.
# Then uploaded photo URLs will point to seed/users/... and nightly reset will not delete them.

# Demo inbox and its Mailpit connection are enabled by docker-compose.eb.template.yml.
APP_DEMO_EMAIL_SANDBOX_SESSION_TTL_MINUTES=180
APP_DEMO_EMAIL_SANDBOX_MAX_MESSAGES=500
APP_DEMO_EMAIL_SANDBOX_DELETE_EXPIRED_MESSAGES=true
APP_DEMO_EMAIL_SANDBOX_CLEANUP_INTERVAL_MILLIS=300000

APP_REPORT_SNAPSHOT_RETENTION_DAYS=180
APP_REPORT_SNAPSHOT_CLEANUP_CRON=0 0 0 * * *
APP_TOKEN_CLEANUP_CRON=0 0 0 * * *

APP_SHOWCASE_BACKEND_GITHUB_URL=https://github.com/your-user/book-exchange
APP_SHOWCASE_FRONTEND_GITHUB_URL=https://github.com/your-user/book-exchange-frontend
APP_SHOWCASE_LINKEDIN_URL=https://tr.linkedin.com/in/your-nickname
APP_SHOWCASE_SWAGGER_URL=https://replace-with-cloudfront-domain.cloudfront.net/api/v1/swagger-ui/index.html

SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true
JAVA_OPTS=-XX:MaxRAMPercentage=75.0
