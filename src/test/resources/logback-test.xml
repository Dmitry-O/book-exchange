<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <logger name="com.example.bookexchange.book.search.ElasticsearchBookSearchIndexService" level="ERROR"/>
    <logger name="com.example.bookexchange.common.jobs.BookPhotoCleanupServiceImpl" level="ERROR"/>
    <logger name="com.example.bookexchange.common.notification.NotificationDispatchServiceImpl" level="ERROR"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
